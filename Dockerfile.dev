# ── Frontend (Vite dev server) ─────────────────────────────────────────────
FROM node:24-slim AS frontend

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@11.1.3 --activate

COPY frontend/pnpm-lock.yaml frontend/package.json ./
RUN pnpm install
COPY frontend/ ./


# ── Backend (Litestar + uv) ────────────────────────────────────────────────
FROM ghcr.io/astral-sh/uv:0.11.15-python3.14-trixie-slim AS backend

WORKDIR /app

# Put the venv outside /app so a bind mount of host code at runtime doesn't
# mask it. Matches UV_PROJECT_ENVIRONMENT in docker-compose.dev.yml.
ENV UV_PROJECT_ENVIRONMENT=/opt/venv

# Project metadata first, so dependency layer is cached when only code changes.
COPY backend/pyproject.toml backend/uv.lock* ./

RUN uv sync --no-cache --link-mode copy

COPY backend/ /app
