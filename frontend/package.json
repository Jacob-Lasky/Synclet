        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-vue": "^10.9.1",
        "happy-dom": "^15.11.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "vite": "^8.0.13",
